// Renovate Bot Configuration — IaC (dev/main, deploys infrastructure)
// Docs: https://docs.renovatebot.com/configuration-options/
//
// KEY DIFFERENCE from library template:
//   - baseBranchPatterns targets the dev branch (staging)
//   - Production deps use fix(deps): prefix (triggers patch release at promotion time)
//
// ADAPT before writing:
//   - baseBranchPatterns: use detected DEV_BRANCH name
//   - enabledManagers: include only detected managers
//   - matchManagers/matchDepTypes: use pep621 values for Python, npm values for Node
//     Python: matchDepTypes "project.dependencies" (prod), "project.optional-dependencies"/"dependency-groups" (dev)
//     Node:   matchDepTypes "dependencies" (prod), "devDependencies" (dev)
//   - matchPackageNames: "python-semantic-release" for Python, "semantic-release" for Node
{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",

  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigestsToSemver"
  ],

  // Target dev branch (staging deploys), not main
  "baseBranchPatterns": ["dev"],

  "schedule": ["before 11:59pm on Sunday"],
  "timezone": "America/Los_Angeles",
  "platformAutomerge": true,
  "rangeStrategy": "auto",

  "enabledManagers": [
    "pep621",
    "pre-commit",
    "github-actions"
  ],

  "labels": ["dependencies", "renovate"],

  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 11:59pm on the first day of the month"],
    "commitMessageAction": "refresh",
    "automerge": true
  },

  "vulnerabilityAlerts": {
    "enabled": true,
    "schedule": ["at any time"],
    "labels": ["dependencies", "security"],
    "commitMessagePrefix": "fix(deps):",
    "automerge": true
  },

  "packageRules": [
    // --- Production dependencies: fix(deps): — triggers patch release ---

    {
      "matchDepTypes": ["project.dependencies"],
      "matchManagers": ["pep621"],
      "matchUpdateTypes": ["patch"],
      "commitMessagePrefix": "fix(deps):",
      "automerge": true
    },
    {
      "matchDepTypes": ["project.dependencies"],
      "matchManagers": ["pep621"],
      "matchUpdateTypes": ["minor"],
      "commitMessagePrefix": "fix(deps):",
      "automerge": false
    },
    {
      "matchDepTypes": ["project.dependencies"],
      "matchManagers": ["pep621"],
      "matchUpdateTypes": ["major"],
      "commitMessagePrefix": "fix(deps):",
      "automerge": false,
      "dependencyDashboardApproval": true
    },

    // --- Dev dependencies: chore(deps-dev): — grouped, no release ---

    {
      "matchDepTypes": ["project.optional-dependencies", "dependency-groups"],
      "matchManagers": ["pep621"],
      "matchUpdateTypes": ["patch", "minor"],
      "commitMessagePrefix": "chore(deps-dev):",
      "automerge": true,
      "groupName": "dev dependency updates",
      "groupSlug": "dev-deps"
    },
    {
      "matchDepTypes": ["project.optional-dependencies", "dependency-groups"],
      "matchManagers": ["pep621"],
      "matchUpdateTypes": ["major"],
      "commitMessagePrefix": "chore(deps-dev):",
      "automerge": false
    },

    // --- python-semantic-release: never automerge ---
    {
      "matchPackageNames": ["python-semantic-release"],
      "automerge": false,
      "commitMessagePrefix": "chore(deps-dev):"
    },

    // --- GitHub Actions ---

    {
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "commitMessagePrefix": "ci(deps):",
      "automerge": true,
      "groupName": "GitHub Actions",
      "groupSlug": "gh-actions"
    },
    {
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["major"],
      "commitMessagePrefix": "ci(deps):",
      "automerge": false,
      "groupName": "GitHub Actions (major)",
      "groupSlug": "gh-actions-major"
    },

    // --- Pre-commit hooks ---
    {
      "matchManagers": ["pre-commit"],
      "commitMessagePrefix": "ci(deps):",
      "automerge": true
    }
  ]
}
